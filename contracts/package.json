{
  "name": "@weekly-commitments/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript contracts for the Weekly Commitments module",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate:client": "openapi-typescript openapi.yaml -o src/generated/openapi.ts",
    "build": "npm run generate:client && tsc --project tsconfig.json",
    "typecheck": "npm run generate:client && tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/ --ext .ts",
    "test": "npm run generate:client && vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.8"
  }
}
