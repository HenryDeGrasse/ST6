{
  "name": "@weekly-commitments/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "E2E acceptance tests for Weekly Commitments (Playwright)",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep SMOKE",
    "test:full": "playwright test",
    "test:nightly": "playwright test --reporter=html,github",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.0"
  }
}
