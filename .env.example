# ---------------------------------------------------------------------------
# Weekly Commitments — Environment Configuration
#
# USAGE:
#   cp .env.example .env          # create your local copy (gitignored)
#   edit .env                     # fill in secrets & overrides
#   ./scripts/dev.sh --seed       # everything reads from .env
#
# ENVIRONMENTS:
#   local   → .env                (this file, your machine)
#   dev     → AWS Secrets Manager + ECS task env
#   staging → AWS Secrets Manager + ECS task env
#   prod    → AWS Secrets Manager + ECS task env
#
# Spring profile is selected by APP_ENV below. Each profile
# (application-{local,dev,staging,prod}.yml) sets behavior defaults
# (log levels, feature flags, AI model). Secrets and connection strings
# are always injected via env vars — never hardcoded in YAML.
# ---------------------------------------------------------------------------

# ── Environment ──────────────────────────────────────────────────────────────
# Which Spring profile + behavior set to activate.
# local = your machine, dev/staging/prod = deployed environments.
APP_ENV=local

# ── Database ─────────────────────────────────────────────────────────────────
# Local: points to Docker Compose Postgres.
# Deployed: RDS endpoint injected by Terraform/Secrets Manager.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=weekly
POSTGRES_USER=weekly
POSTGRES_PASSWORD=weekly

# ── Redis ────────────────────────────────────────────────────────────────────
# Local: Docker Compose Redis. Deployed: ElastiCache endpoint.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backend ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── AI Provider ──────────────────────────────────────────────────────────────
# "stub"       → fake deterministic responses (no key needed, good for UI work)
# "openrouter" → real LLM via OpenRouter (get key at https://openrouter.ai/keys)
AI_PROVIDER=stub

# OpenRouter settings (only used when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── LocalStack (local only) ─────────────────────────────────────────────────
LOCALSTACK_PORT=4566
AWS_DEFAULT_REGION=us-east-1

# ── Seed Data IDs (local only) ──────────────────────────────────────────────
DEV_ORG_ID=a0000000-0000-0000-0000-000000000001
DEV_USER_ID=c0000000-0000-0000-0000-000000000001
