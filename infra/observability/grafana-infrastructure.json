{
  "dashboard": {
    "title": "WC Infrastructure",
    "description": "Weekly Commitments – ECS, RDS, Redis, SQS, and ALB infrastructure metrics (PRD §14.3)",
    "tags": ["weekly-commitments", "infrastructure"],
    "timezone": "utc",
    "refresh": "30s",
    "panels": [
      {
        "title": "ECS Task Count",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
        "targets": [
          {
            "expr": "aws_ecs_running_task_count_maximum{service_name=\"weekly-service\"}",
            "legendFormat": "running tasks"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "green", "value": 2 }
              ]
            }
          }
        }
      },
      {
        "title": "ECS CPU Utilization per Task",
        "type": "timeseries",
        "gridPos": { "x": 4, "y": 0, "w": 10, "h": 4 },
        "targets": [
          {
            "expr": "aws_ecs_cpu_utilization_average{service_name=\"weekly-service\"}",
            "legendFormat": "CPU %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 85 }
              ]
            }
          }
        }
      },
      {
        "title": "ECS Memory Utilization per Task",
        "type": "timeseries",
        "gridPos": { "x": 14, "y": 0, "w": 10, "h": 4 },
        "targets": [
          {
            "expr": "aws_ecs_memory_utilization_average{service_name=\"weekly-service\"}",
            "legendFormat": "Memory %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 75 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "title": "RDS Connections",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_rds_database_connections_average{db_instance_identifier=\"weekly-db\"}",
            "legendFormat": "connections"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 80 },
                { "color": "red", "value": 100 }
              ]
            }
          }
        }
      },
      {
        "title": "RDS IOPS",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 4, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_rds_read_iops_average{db_instance_identifier=\"weekly-db\"}",
            "legendFormat": "read IOPS"
          },
          {
            "expr": "aws_rds_write_iops_average{db_instance_identifier=\"weekly-db\"}",
            "legendFormat": "write IOPS"
          }
        ]
      },
      {
        "title": "RDS Replication Lag",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 4, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_rds_replica_lag_average{db_instance_identifier=\"weekly-db-replica\"}",
            "legendFormat": "replication lag (s)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 30 },
                { "color": "red", "value": 60 }
              ]
            }
          }
        }
      },
      {
        "title": "Redis Memory Usage",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 9, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_elasticache_bytes_used_for_cache_average{cache_cluster_id=\"weekly-redis\"}",
            "legendFormat": "used bytes"
          },
          {
            "expr": "aws_elasticache_freeable_memory_average{cache_cluster_id=\"weekly-redis\"}",
            "legendFormat": "freeable bytes"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "bytes" }
        }
      },
      {
        "title": "Redis Cache Hit / Miss Rate",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 9, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_elasticache_cache_hits_average{cache_cluster_id=\"weekly-redis\"}",
            "legendFormat": "hits/s"
          },
          {
            "expr": "aws_elasticache_cache_misses_average{cache_cluster_id=\"weekly-redis\"}",
            "legendFormat": "misses/s"
          }
        ]
      },
      {
        "title": "Redis Connections",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 9, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_elasticache_curr_connections_average{cache_cluster_id=\"weekly-redis\"}",
            "legendFormat": "connections"
          }
        ]
      },
      {
        "title": "SQS Queue Depth",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 14, "w": 12, "h": 5 },
        "targets": [
          {
            "expr": "aws_sqs_approximate_number_of_messages_visible_maximum{queue_name=~\"weekly-.*\"}",
            "legendFormat": "{{ queue_name }}"
          }
        ]
      },
      {
        "title": "SQS Message Age (Oldest)",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 14, "w": 12, "h": 5 },
        "targets": [
          {
            "expr": "aws_sqs_approximate_age_of_oldest_message_maximum{queue_name=~\"weekly-.*\"}",
            "legendFormat": "{{ queue_name }} age (s)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 60 },
                { "color": "red", "value": 300 }
              ]
            }
          }
        }
      },
      {
        "title": "ALB Request Count",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 19, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_alb_request_count_sum{load_balancer=~\"weekly-.*\"}",
            "legendFormat": "requests"
          }
        ]
      },
      {
        "title": "ALB Target Response Time",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 19, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_alb_target_response_time_average{load_balancer=~\"weekly-.*\"}",
            "legendFormat": "avg response time (s)"
          },
          {
            "expr": "aws_alb_target_response_time_p99{load_balancer=~\"weekly-.*\"}",
            "legendFormat": "p99 response time (s)"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "ALB Healthy / Unhealthy Targets",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 19, "w": 8, "h": 5 },
        "targets": [
          {
            "expr": "aws_alb_healthy_host_count_average{load_balancer=~\"weekly-.*\"}",
            "legendFormat": "healthy"
          },
          {
            "expr": "aws_alb_un_healthy_host_count_average{load_balancer=~\"weekly-.*\"}",
            "legendFormat": "unhealthy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 }
              ]
            }
          }
        }
      }
    ]
  }
}
